{
  "containers": [
    {
      "name": "tailscale",
      "image": "docker.io/tailscale/tailscale:stable",
      "entrypoint": ["/bin/sh", "/config/start.sh"],
      "files": [
        {
          "guest_path": "/config/start.sh",
          "local_path": "tailscale-start.sh",
          "mode": 493
        }
      ],
      "healthchecks": [
        {
          "name": "tailscale-status",
          "kind": "readiness",
          "exec": {
            "command": [
              "/usr/local/bin/tailscale",
              "--socket=/shared/tailscale.sock",
              "status"
            ]
          },
          "interval": 10,
          "timeout": 5,
          "grace_period": 30,
          "success_threshold": 1,
          "failure_threshold": 3
        }
      ],
      "mounts": [
        {
          "name": "shared",
          "path": "/shared"
        }
      ]
    },
    {
      "name": "proxyt",
      "image": "ghcr.io/jaxxstorm/proxyt:latest",
      "depends_on": [
        {
          "name": "tailscale",
          "condition": "healthy"
        }
      ],
      "mounts": [
        {
          "name": "shared",
          "path": "/shared"
        }
      ]
    },
    {
      "name": "mtproxy",
      "image": "telegrammessenger/proxy:latest",
      "depends_on": [
        {
          "name": "tailscale",
          "condition": "started"
        }
      ],
      "mounts": [
        {
          "name": "shared",
          "path": "/shared"
        }
      ]
    }
  ],
  "volumes": [
    {
      "name": "shared",
      "temp_dir": {
        "size_mb": 10
      }
    }
  ],
  "guest": {
    "cpus": 1,
    "cpu_kind": "shared",
    "memory_mb": 256
  }
}
