	"grants": [
		{
			"src": ["*"],
			"dst": ["*", "autogroup:internet"],
			"ip":  ["*"],
		},
	],

	"autoApprovers": {
		"exitNode": ["autogroup:tagged"],

		"routes": {
			"0.0.0.0/0": ["autogroup:tagged"],
			"::/0":      ["autogroup:tagged"],
		},
	},

	"tagOwners": {
		"tag:vpn": ["autogroup:member"],
		"tag:eu":  ["autogroup:member"],
		"tag:ru":  ["autogroup:member"],
